# Private-Pay — Base, ENS, BitGo only
# Copy to .env and fill in values. Never commit .env.

# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Base (Sepolia)
VITE_BASE_CHAIN_ID=84532
VITE_BASE_RPC_URL=https://sepolia.base.org
VITE_BASE_MAINNET_RPC_URL=https://mainnet.base.org
VITE_BASE_ASSET_SYMBOL=USDC
VITE_BASE_ASSET_ADDRESS=
VITE_BASE_ASSET_DECIMALS=6

# Ethereum mainnet (ENS resolution only)
VITE_ETH_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com
VITE_ETH_SEPOLIA_RPC_URL=https://rpc.sepolia.org
VITE_ENS_CHAIN=mainnet

# Treasury (shared for Base / ENS / BitGo)
VITE_SHARED_TREASURY_ADDRESS=0x...
VITE_BASE_TREASURY_ADDRESS=0x...
VITE_ENS_TREASURY_ADDRESS=0x...
VITE_BITGO_TREASURY_ADDRESS=0x...

# BitGo (test)
VITE_BITGO_API_URL=https://app.bitgo-test.com/api/v2
VITE_BITGO_ACCESS_TOKEN=
VITE_BITGO_WALLET_ID=
VITE_BITGO_COIN=tbaseeth
VITE_BITGO_ENV=test
VITE_BITGO_ASSET_SYMBOL=tBaseETH

# Relayer / backend (withdraw uses this key; keep secret)
VITE_TREASURY_PRIVATE_KEY=
TREASURY_PRIVATE_KEY=

# Optional
# VITE_WEBSITE_HOST=private-pay-iqgp.vercel.app
# VITE_BACKEND_URL=http://localhost:3400
